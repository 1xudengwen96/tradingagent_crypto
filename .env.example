# =============================================================================
# TradingAgents Crypto — 环境变量配置模板
# 复制此文件为 .env 并填写你的值：cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# 飞书机器人 Webhook（用于接收交易分析通知）
# 获取地址：在飞书群聊中添加自定义机器人，复制 Webhook 地址
# 
# 多角色机器人配置（每个角色一个 Webhook，共 5 个）
# 详细搭建指南：参见 FEISHU_MULTI_BOT_GUIDE.md
# 
# 角色说明：
#   📊 市场分析师  - 推送 K线分析、指标信号、市场情绪
#   💬 辩论员      - 推送多空观点辩论（看多理由 vs 看空理由）
#   🛡️ 风控官      - 推送风险等级、仓位建议、止损止盈
#   💰 交易员      - 推送开仓/平仓指令、订单状态
#   通用通知       - 保留原有功能，推送汇总分析结果
# 
# 如果只需要单一通知，只填 FEISHU_WEBHOOK_URL 即可
# 如果要启用多角色通知，请在飞书群内创建 4 个自定义机器人，分别填写对应 Webhook
# -----------------------------------------------------------------------------

# 通用通知 Webhook（可选，保留向后兼容）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxxxxxxxxxxxxxxxx

# 📊 市场分析师 Webhook（技术分析结果推送）
FEISHU_WEBHOOK_ANALYST=

# 💬 辩论员 Webhook（多空辩论结果推送）
FEISHU_WEBHOOK_DEBATER=

# 🛡️ 风控官 Webhook（风险评估推送）
FEISHU_WEBHOOK_RISK=

# 💰 交易员 Webhook（交易执行结果推送）
FEISHU_WEBHOOK_TRADER=

# -----------------------------------------------------------------------------
# LLM 提供商 - 仅使用通义千问(Qwen)作为唯一AI提供商
# 获取地址：https://dashscope.console.aliyun.com/
# 推荐使用: qwen-max (深度分析) + qwen-plus (快速决策)
# -----------------------------------------------------------------------------
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# QWEN_API_KEY=  # 备用，与 DASHSCOPE_API_KEY 等价

# 以下LLM提供商已不再使用，请注释掉或删除:
# ANTHROPIC_API_KEY=  # 已弃用
# OPENAI_API_KEY=     # 已弃用
# GOOGLE_API_KEY=     # 已弃用
# XAI_API_KEY=        # 已弃用
# OPENROUTER_API_KEY= # 已弃用

# -----------------------------------------------------------------------------
# Bitget 交易所 API（永续合约交易）
# 获取地址：https://www.bitget.com/zh-CN/account/newcreate
# 沙盒地址：https://www.bitget.com/zh-CN/account/newcreate（开启 Demo Trading）
# -----------------------------------------------------------------------------
BITGET_API_KEY=bg_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BITGET_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BITGET_PASSPHRASE=your_passphrase_here

# true = 沙盒模式（推荐测试时使用），false = 实盘交易（谨慎！）
BITGET_SANDBOX=true

# 账户类型：classic = 经典账户（默认），uma = 统一账户
# 大多数用户使用 classic 即可
BITGET_ACCOUNT_TYPE=classic

# -----------------------------------------------------------------------------
# CryptoPanic 新闻 API（可选）
# 无 Key 时使用公共 API，限速 60次/小时
# 获取地址：https://cryptopanic.com/developers/api/
# -----------------------------------------------------------------------------
CRYPTOPANIC_API_KEY=

# -----------------------------------------------------------------------------
# 交易参数（可选，覆盖 default_config.py 中的默认值）
# -----------------------------------------------------------------------------
# 每次交易使用的资金量（USDT）
CAPITAL_USDT=1000

# -----------------------------------------------------------------------------
# 调试选项
# -----------------------------------------------------------------------------
# true = 开启 LangGraph 详细 debug 输出（显示每个 agent 的中间状态）
DEBUG=false
