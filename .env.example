# =============================================================================
# TradingAgents Crypto — 环境变量配置模板
# 复制此文件为 .env 并填写你的值：cp .env.example .env
#
# 📚 完整配置指南：
#   - FEISHU_ROLE_CONFIG_GUIDE.md - 飞书多角色配置与提示词优化指南
#   - FEISHU_MULTI_BOT_GUIDE.md - 飞书机器人搭建教程
# =============================================================================

# -----------------------------------------------------------------------------
# 📱 飞书机器人 Webhook（用于接收交易分析通知）
#
# 🎯 配置策略（二选一）：
#
#   方案 A【推荐 - 透明化监控】：每个角色独立通知
#     - 优点：每个 AI 的分析过程独立可见，便于验证和调试
#     - 缺点：需要创建多个飞书群和机器人
#     - 适用：严肃的量化交易，需要严格监控 AI 行为
#
#   方案 B【简化 -  consolidated 通知】：所有角色通知到一个群
#     - 优点：配置简单，只需一个机器人
#     - 缺点：无法单独追踪每个角色的分析过程
#     - 适用：快速测试或简化部署
#
# 🔧 获取 Webhook 地址：
#   1. 在飞书群聊中点击右上角「群设置」
#   2. 选择「机器人」→「添加机器人」
#   3. 选择「自定义机器人」，填写名称
#   4. 复制生成的 Webhook 地址
#
# 🤖 角色说明（重要：实际使用 vs 预留）：
#
# 【✅ 实际使用的角色 - 对应代码中的 4 个核心 Agent】
#   📈 市场分析师      → tradingagents/agents/analysts/crypto_technical_analyst.py
#                        技术分析（OHLCV、RSI、MACD、均线、趋势判断）
#   💎 宏观/链上分析师  → tradingagents/agents/analysts/crypto_macro_onchain_analyst.py
#                        宏观数据 + 链上数据（资金费率、持仓量、订单簿、新闻）
#   ⚖️ 研究经理        → tradingagents/agents/managers/crypto_research_manager.py
#                        综合技术面和宏观面报告，识别一致性和分歧
#   🎯 投资组合经理     → tradingagents/agents/managers/crypto_portfolio_manager.py
#                        最终交易决策 + Python 硬编码仓位计算（ATR 模型）
#
# 【⚠️ 预留角色 - 已合并到上述角色中，飞书通知拆分显示以便监控】
#   😊 情绪分析师      ← 宏观/链上分析师的一部分（资金费率、持仓量、订单簿情绪）
#   📰 新闻分析师      ← 宏观/链上分析师的一部分（宏观新闻、ETF 流向、监管政策）
#   💎 基本面分析师    ← 宏观/链上分析师的一部分（链上数据、交易所流向）
#   🛡️ 风险经理        ← 投资组合经理的一部分（Python 硬编码风控计算）
#
# ℹ️ 说明：
#   - 实际代码中只有 4 个核心角色（v2.0 精简版）
#   - 飞书通知保留 8 个角色接口，是为了更细致地监控分析过程
#   - 情绪/新闻/基本面分析师的数据都来自 Macro Onchain Analyst
#   - 风险经理的评估由 Portfolio Manager 中的 Python 代码计算
#
# ⚠️ 重要提示：
#   - 如果某个角色留空，该角色的分析结果将不会发送飞书通知
#   - 建议至少配置 FEISHU_WEBHOOK_URL 作为后备通知渠道
# -----------------------------------------------------------------------------

# 【必填】通用通知 Webhook（后备通知渠道，所有角色留空时使用此配置）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# 【✅ 实际使用的角色】
# ─────────────────────────────────────────────────────────────────────────────

# 【✅ 使用】📈 市场分析师 Webhook（技术分析结果推送）
# 对应代码：tradingagents/agents/analysts/crypto_technical_analyst.py
# 分析内容：OHLCV 数据、技术指标（RSI/MACD/布林带等）、趋势判断、支撑阻力位
FEISHU_WEBHOOK_ANALYST=

# 【✅ 使用】⚖️ 研究经理 Webhook（研究经理裁决推送）
# 对应代码：tradingagents/agents/managers/crypto_research_manager.py
# 分析内容：综合技术面和宏观面报告，指出一致性和分歧，给出综合判断
FEISHU_WEBHOOK_MANAGER=

# 【✅ 使用】🎯 交易员 Webhook（最终交易决策推送）
# 对应代码：tradingagents/agents/managers/crypto_portfolio_manager.py
# 分析内容：开仓/平仓方向、订单执行结果、交易 ID、仓位计算
FEISHU_WEBHOOK_TRADER=

# ─────────────────────────────────────────────────────────────────────────────
# 【⚠️ 预留角色】- 以下角色的数据来自 Macro Onchain Analyst，拆分显示便于监控
# ─────────────────────────────────────────────────────────────────────────────

# 【⚠️ 预留】😊 情绪分析师 Webhook（情绪分析结果推送）
# 数据来源：tradingagents/agents/analysts/crypto_macro_onchain_analyst.py
# 分析内容：资金费率、持仓量、订单簿深度、市场情绪指标
FEISHU_WEBHOOK_SENTIMENT=

# 【⚠️ 预留】📰 新闻分析师 Webhook（新闻分析结果推送）
# 数据来源：tradingagents/agents/analysts/crypto_macro_onchain_analyst.py
# 分析内容：宏观新闻、ETF 流向、监管政策、美联储决议
FEISHU_WEBHOOK_NEWS=

# 【⚠️ 预留】💎 基本面分析师 Webhook（基本面/链上数据分析推送）
# 数据来源：tradingagents/agents/analysts/crypto_macro_onchain_analyst.py
# 分析内容：交易所资金流向、巨鲸转账、链上数据、大户持仓
FEISHU_WEBHOOK_FUNDAMENTALS=

# 【⚠️ 预留】🛡️ 风险经理 Webhook（风险评估推送）
# 数据来源：tradingagents/agents/managers/crypto_portfolio_manager.py（Python 风控计算）
# 分析内容：仓位建议、杠杆倍数、止损位、止盈位、风险评估
FEISHU_WEBHOOK_RISK=

# -----------------------------------------------------------------------------
# LLM 提供商 - 仅使用通义千问 (Qwen) 作为唯一 AI 提供商
# 获取地址：https://dashscope.console.aliyun.com/
# 推荐使用：qwen-max (深度分析) + qwen-plus (快速决策)
# -----------------------------------------------------------------------------
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 以下 LLM 提供商已不再使用，请注释掉或删除:
# ANTHROPIC_API_KEY=  # 已弃用
# OPENAI_API_KEY=     # 已弃用
# GOOGLE_API_KEY=     # 已弃用
# XAI_API_KEY=        # 已弃用
# OPENROUTER_API_KEY= # 已弃用

# -----------------------------------------------------------------------------
# Bitget 交易所 API（永续合约交易）
# 获取地址：https://www.bitget.com/zh-CN/account/newcreate
# 沙盒地址：https://www.bitget.com/zh-CN/account/newcreate（开启 Demo Trading）
# -----------------------------------------------------------------------------
BITGET_API_KEY=bg_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BITGET_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BITGET_PASSPHRASE=your_passphrase_here

# true = 沙盒模式（推荐测试时使用），false = 实盘交易（谨慎！）
BITGET_SANDBOX=true

# 账户类型：classic = 经典账户（默认），uma = 统一账户
# 大多数用户使用 classic 即可
BITGET_ACCOUNT_TYPE=classic

# -----------------------------------------------------------------------------
# CryptoPanic 新闻 API（可选）
# 无 Key 时使用公共 API，限速 60 次/小时
# 获取地址：https://cryptopanic.com/developers/api/
# -----------------------------------------------------------------------------
CRYPTOPANIC_API_KEY=

# -----------------------------------------------------------------------------
# 交易参数（可选，覆盖 default_config.py 中的默认值）
# -----------------------------------------------------------------------------
# 每次交易使用的资金量（USDT）
CAPITAL_USDT=1000

# K 线周期设置：4h = 4 小时线（默认），1d = 日线
# 4H 周期：每 4 小时执行一次 (0, 4, 8, 12, 16, 20 点)
# 1D 周期：每日 08:00 (UTC+8) 执行全局扫描
TIMEFRAME=4h

# -----------------------------------------------------------------------------
# 调试选项
# -----------------------------------------------------------------------------
# true = 开启 LangGraph 详细 debug 输出（显示每个 agent 的中间状态）
DEBUG=false
